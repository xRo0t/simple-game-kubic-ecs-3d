# Components — بيانات بس
struct Position:  x: f32 = 0.0  |  y: f32 = 0.0  |  z: f32 = 0.0
struct Velocity:  x: f32 = 0.0  |  z: f32 = 0.0
struct Speed:     value: f32 = 5.0

# System — function تاخد components وتشتغل عليها
fun movement_system(pos: Position, vel: Velocity, dt: f32) -> void:
    pos.x = pos.x + vel.x * dt
    pos.z = pos.z + vel.z * dt

# Entity = رقم بس
player: i32 = world.spawn()
world.add(player, Position())
world.add(player, Velocity())





مرحبا،

راجعت كود simple-game-kubic-ecs-3d كامل وعندي ملاحظات
تقنية على البنية — أرجو تتحقق منها:

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

[1] ren يتمرر يدوياً لكل function
━━━━━━━━━━━
في main.dlt:

    spawn_world(s, ren, ents)
    spawn_player(s, ren, player, ...)
    update_player(s, ren, player, dt)

الـ Renderer مش جزء من الـ ECS Scene —
يعني المطور مضطر يمرره يدوياً لكل function.
لو نسيه بمكان = silent bug صعب يتلاقى.

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

[2] PlayerState مش ECS — هو OOP مخفي
━━━━━━━━━━━
في player.dlt:

    struct PlayerState:
        entity_id:  i32
        camera_id:  i32
        move_speed: f32
        yaw:        f32
        pitch:      f32
"""
هاد struct يحمل entity IDs جوا نفسه —
يعني هو يتصرف كـ god object مش كـ component.
الصح ECS:
"""
    struct Player:       ← component بس
        move_speed: f32
        yaw:        f32
        pitch:      f32

    # camera_id يصير linked entity منفصل
    # مش محشور جوا PlayerState

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

#[3] update_player مش system حقيقي
━━━━━━━━━━━
#في controller.dlt:

    fun update_player(w, ren, player: PlayerState, dt):
        px = Node3D.get_pos_x(w, player.entity_id)
        ...

#هاد يشتغل على entity واحد محدد يدوياً.
#الصح ECS:

    fun movement_system(scene: Scene, dt: f32):
        q: Query = scene.query2("Player", "Transform")
        while q.next():
            # يشتغل على كل entity تلقائياً

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

[4] Node.update_matrix يدوي = bug محتمل
━━━━━━━━━━━
في controller.dlt:

    Node3D.set_pos(w, player.entity_id, px, py, pz)
    Node.update_matrix(w, ren, player.entity_id)  ← يدوي

لو المطور استدعى set_pos ونسي update_matrix
= اللاعب يتحرك بالـ ECS بس ما يتحرك بالشاشة.
يجب update_matrix تصير تلقائية جوا set_pos.

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

[5] 90,000 draw call بدون instancing
━━━━━━━━━━━
في earth.dlt:

    grid: i32 = 300   ← 300 x 300 = 90,000 cube

وفي renderer.dlt كل cube = draw call منفصل:

    vkCmdDraw(cmd, vc, 1, 0, 0)
                       ↑
                 instanceCount = 1

= ~20 FPS على أي جهاز.
الحل: vkCmdDraw(cmd, vc, instance_count, 0, 0)
مع Instanced Rendering.

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

[6] WorldEntities غير مفيد
━━━━━━━━━━━
في earth.dlt:

    struct WorldEntities:
        ground_id:  i32 = -1
        cube_count: i32 = 0

#ground_id مش مستخدم بعد الـ spawn.
#cube_count بس للـ print.
#الـ struct بحد ذاته مافيه قيمة فعلية.

